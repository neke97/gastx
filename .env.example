# === Supabase ===
# Obtené estos valores en tu proyecto de Supabase:
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key

# NUNCA pongas la service_role key con prefijo NEXT_PUBLIC_ (es secreta y solo de servidor).
# Descomentá solo si la necesitás en el servidor:
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
