# === Supabase ===
# Obtené estos valores en tu proyecto de Supabase:
# Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key

# NUNCA pongas la service_role key con prefijo NEXT_PUBLIC_ (es secreta y solo de servidor).
# Necesaria para el cron de recurrentes (generación automática):
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# === Cron (generación automática de recurrentes en Vercel) ===
# Secreto para proteger /api/cron/generate-recurring. Poné el mismo valor en
# Vercel (Project Settings -> Environment Variables). Vercel Cron lo envía como
# "Authorization: Bearer <CRON_SECRET>".
# CRON_SECRET=un-secreto-largo-y-aleatorio

# === PayPal (suscripciones) ===
# Credenciales de la app en https://developer.paypal.com -> Apps & Credentials.
# Usá "sandbox" para pruebas y "live" en producción.
# PAYPAL_ENV=sandbox
# PAYPAL_CLIENT_ID=tu-client-id
# PAYPAL_CLIENT_SECRET=tu-client-secret          # SECRETO, solo servidor
# PAYPAL_WEBHOOK_ID=id-del-webhook               # de Webhooks en el dashboard

# El client id también se expone al navegador para renderizar los botones:
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=tu-client-id

# IDs de plan creados con:  node scripts/paypal-setup-plans.mjs
# (deben empezar con "P-"). Se exponen al cliente para crear la suscripción.
# NEXT_PUBLIC_PAYPAL_PLAN_MONTHLY=P-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_PAYPAL_PLAN_ANNUAL=P-XXXXXXXXXXXXXXXX
